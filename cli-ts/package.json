{
  "name": "dockflow",
  "version": "2.0.23",
  "description": "A deployment framework for Docker applications, leveraging Swarm for orchestration",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "dockflow": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run scripts/build.ts",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile=dist/dockflow-linux",
    "build:windows": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile=dist/dockflow.exe",
    "build:macos": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=dist/dockflow-macos",
    "build:macos-intel": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile=dist/dockflow-macos-intel",
    "build:all": "bun run build:linux && bun run build:windows && bun run build:macos && bun run build:macos-intel",
    "typecheck": "tsc --noEmit",
    "ui:install": "cd ui && pnpm install",
    "ui:dev": "cd ui && pnpm start",
    "ui:build": "cd ui && pnpm build",
    "ui": "bun run src/index.ts ui"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "@types/nunjucks": "3.2.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ignore": "7.0.5",
    "nunjucks": "3.2.4",
    "shawiizz-decomposerize": "1.5.12",
    "ssh2": "^1.17.0",
    "tar-stream": "3.1.8",
    "yaml": "^2.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/ssh2": "^1.15.5",
    "@types/tar-stream": "3.1.4",
    "typescript": "^5.9.3"
  },
  "author": "Shawiizz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shawiizz/dockflow"
  }
}
